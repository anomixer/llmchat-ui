# 預設 AI 供應商設定 (第一次打開網頁時使用)
# 可選類型: ollama, openai, deepseek, groq, custom
VITE_DEFAULT_PROVIDER_TYPE=ollama

# Ollama 服務的 API URL (如果使用 Ollama)
VITE_OLLAMA_API_URL=http://localhost:11434

# 預設 API 金鑰 (如果使用雲端大模型)
VITE_DEFAULT_API_KEY=

# 預設啟用的模型名稱
VITE_DEFAULT_MODEL=llama3

# Vite 開發伺服器允許的額外主機名稱列表 (以逗號分隔)
# 例如: VITE_ALLOWED_HOSTS=llmchat.example.com,your-domain.com
# 註: localhost 與 127.0.0.1 預設已允許
VITE_ALLOWED_HOSTS=